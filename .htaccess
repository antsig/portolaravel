<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1. Protect sensitive files and directories from public access
    RedirectMatch 403 /\.(git|gitignore|env|docker|github|vscode)
    RedirectMatch 403 /(composer\.json|composer\.lock|package\.json|package-lock\.json|artisan|phpunit\.xml|vite\.config\.js)
    RedirectMatch 403 /app/
    RedirectMatch 403 /bootstrap/
    RedirectMatch 403 /config/
    RedirectMatch 403 /database/
    RedirectMatch 403 /resources/
    RedirectMatch 403 /routes/
    RedirectMatch 403 /storage/
    RedirectMatch 403 /tests/
    RedirectMatch 403 /vendor/

    # 2. Redirect all other requests to the public directory
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
